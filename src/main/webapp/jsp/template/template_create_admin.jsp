<%@ page contentType="text/html;charset=UTF-8" language="java" %><html><head>    <link rel="stylesheet" href="css/template_create.css">    <title>관리자 - 새 템플릿 등록</title></head><body><div class="reg-container">    <h2>🆕 새 템플릿 등록</h2>    <form action="template-create-admin" method="post" enctype="multipart/form-data">        <div class="row">            <label>템플릿 이름</label>            <input type="text" name="name" placeholder="예: 단풍 템플릿" required>        </div>        <div class="row">            <label>HTML 구조 ({{content}} 포함)</label>            <input name="bgColor" placeholder="ffffff" required/>        </div>        <div class="row">            <label>타입 선택</label>            <select name="type">                <option value="BASE">기본 (BASE)</option>                <option value="ADDED">추가 (ADDED)</option>            </select>        </div>        <div class="row">            <label>커버 이미지 업로드</label>            <input type="file" name="coverImgUrl" accept="image/*" required>        </div>        <button type="submit">등록하기</button>    </form></div></body></html>
<%@ page contentType="text/html;charset=UTF-8" language="java" %><html><head>    <title>관리자 - 새 템플릿 등록</title>    <style>        .reg-container {            width: 500px;            margin: 20px auto;            padding: 20px;            border: 1px solid #ddd;            background: #f9f9f9;            border-radius: 10px;        }        .row {            margin-bottom: 15px;        }        label {            display: block;            font-weight: bold;            margin-bottom: 5px;        }        input[type="text"], textarea, select {            width: 100%;            padding: 8px;            border: 1px solid #ccc;            border-radius: 4px;            box-sizing: border-box;        }        textarea {            height: 150px;            font-family: monospace;        }        button {            width: 100%;            padding: 10px;            background-color: #4CAF50;            color: white;            border: none;            border-radius: 4px;            cursor: pointer;            font-size: 16px;        }        button:hover {            background-color: #45a049;        }    </style></head><body><div class="reg-container">    <h2>🆕 새 템플릿 등록</h2>    <form action="template-create-admin" method="post" enctype="multipart/form-data">        <div class="row">            <label>템플릿 이름</label>            <input type="text" name="name" placeholder="예: 단풍 템플릿" required>        </div>        <div class="row">            <label>HTML 구조 ({{content}} 포함)</label>            <textarea name="bodyHtml" placeholder="<div class='theme'>{{content}}</div>" required></textarea>        </div>        <div class="row">            <label>타입 선택</label>            <select name="type">                <option value="BASE">기본 (BASE)</option>                <option value="ADDED">추가 (ADDED)</option>            </select>        </div>        <div class="row">            <label>커버 이미지 업로드</label>            <input type="file" name="coverImgUrl" accept="image/*" required>        </div>        <button type="submit">등록하기</button>    </form></div></body></html>
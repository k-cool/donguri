<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %><div id="templateDetailArea">    <h2>${t.name}</h2>    <hr>    <div class="cover-img-box">        <img src="${t.coverImgUrl}" alt="템플릿 커버" style="max-width: 300px;">    </div>    <div class="template-body">        ${t.bodyHtml}    </div>    <div class="button-area">        <c:choose>            <%-- 1. 이미 내 보관함에 있다면? --%>            <c:when test="${isEnrolled}">                <button type="button" class="use-btn">                    엽서 쓰기 ✍️                </button>                <p style="color: gray; font-size: 0.8rem;">이미 내 보관함에 있는 템플릿입니다.</p>            </c:when>            <%-- 2. 아직 보관함에 없다면? (QR로 처음 들어온 경우 등) --%>            <c:otherwise>                <form action="template.enroll" method="post">                    <input type="hidden" name="templateId" value="${t.templateId}">                    <button type="submit" class="enroll-btn">내 보관함에 담기 📥</button>                </form>            </c:otherwise>        </c:choose>    </div></div>
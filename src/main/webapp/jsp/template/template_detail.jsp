<%@ page contentType="text/html;charset=UTF-8" pageEncoding="UTF-8" language="java" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><html><head>    <title>Template Detail</title>    <style>        /* 중앙 정렬 레이아웃 */        .detail-container {            max-width: 600px;            margin: 50px auto;            text-align: center;            padding: 20px;            background: #fff;            border-radius: 20px;            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);        }        /* 이미지 스타일 */        .detail-img {            width: 80%;            max-width: 400px;            border-radius: 10px;            margin-bottom: 20px;        }        /* 텍스트 정보 */        .info-group {            margin-bottom: 30px;        }        .info-group h1 {            font-size: 28px;            margin-bottom: 10px;        }        .info-group p {            color: #666;            line-height: 1.6;        }        /* 버튼 스타일 */        .btn-action {            display: inline-block;            padding: 15px 40px;            font-size: 18px;            font-weight: bold;            border-radius: 30px;            text-decoration: none;            transition: 0.3s;            border: none;            cursor: pointer;        }        /* 관리자용 수정 버튼 */        .btn-edit {            background-color: #ff4757;            color: white;        }        .btn-edit:hover {            background-color: #ff6b81;        }        /* 유저용 엽서 쓰기 버튼 */        .btn-write {            background-color: #2f3542;            color: white;        }        .btn-write:hover {            background-color: #57606f;        }        .meta-info {            font-size: 12px;            color: #aaa;            margin-top: 40px;        }    </style></head><body><div class="detail-container">    <c:choose>        <c:when test="${not empty t.coverImgUrl}">            <img src="${t.coverImgUrl}" alt="${t.name}" class="detail-img">        </c:when>        <c:otherwise>            <img src="img/no_image.png" alt="이미지 없음" class="detail-img">        </c:otherwise>    </c:choose>    <div class="info-group">        <span>[ ${t.type} ]</span>        <h1>${t.name}</h1>        <hr style="width: 50px; margin: 20px auto; border: 1px solid #eee;">        <p>${t.bodyHtml}</p>    </div>    <div class="action-group">        <c:choose>            <c:when test="${isAdminView}">                <a href="template.edit?no=${t.templateId}" class="btn-action btn-edit">                    🛠️ 템플릿 정보 수정하기                </a>            </c:when>            <%-- 2. 일반 유저인 경우: 엽서 쓰기 버튼 노출 --%>            <c:otherwise>                <a href="postcard.write?id=${t.templateId}" class="btn-action btn-write">  <%--TODO: 엽서 작성 페이지로 이동--%>                    📝 이 템플릿으로 엽서 쓰기                </a>            </c:otherwise>        </c:choose>    </div>    <div class="meta-info">        ID: ${t.templateId} <br>        등록일: ${t.createdAt} | 수정일: ${t.updatedAt}    </div></div></body></html>
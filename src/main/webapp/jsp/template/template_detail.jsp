<%@ page contentType="text/html;charset=UTF-8" pageEncoding="UTF-8" language="java" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><html><head>    <link rel="stylesheet" href="css/template_detail.css">    <title>Template Detail</title></head><body><div class="detail-container" style="background-color: ${t.bgColor}66;">    <div class="img-wrapper">        <div class="img-box">            <c:choose>                <c:when test="${not empty t.coverImgUrl}">                    <img src="${t.coverImgUrl}" alt="${t.name}" class="detail-img">                </c:when>                <c:otherwise>                    <img src="img/no_image.png" alt="이미지 없음" class="detail-img">                </c:otherwise>            </c:choose>        </div>    </div>    <div class="info-group">        <span>[ ${t.type} ]</span>        <h1>${t.name}</h1>        <hr style="width: 50px; margin: 20px auto; border: 1px solid #eee;">    </div>    <div class="action-group">        <%--        TODO: reservation write 화면에서 템플릿 미리 선택되도록 하기--%>        <a href="reservation?action=write&templateId=${t.templateId}" class="btn-action btn-write">            📝 이 템플릿으로 엽서 쓰기        </a>    </div></div></body></html>
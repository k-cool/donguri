<%@ page contentType="text/html;charset=UTF-8" pageEncoding="UTF-8" language="java" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><link rel="stylesheet" href="css/template_detail_admin.css"><title>Template Detail</title><div class="detail-container">    <c:choose>        <c:when test="${not empty t.coverImgUrl}">            <img src="${t.coverImgUrl}" alt="${t.name}" class="detail-img">        </c:when>        <c:otherwise>            <img src="img/no_image.png" alt="이미지 없음" class="detail-img">        </c:otherwise>    </c:choose>    <div class="info-group">        <span>[ ${t.type} ]</span>        <h1>${t.name}</h1>        <hr style="width: 50px; margin: 20px auto; border: 1px solid #eee;">        <p>#${t.bgColor}</p>    </div>    <div class="action-group">        <a href="template-update-admin?templateId=${t.templateId}" class="btn-action">            템플릿 정보 수정하기        </a>        <%--        템플릿 데이터 삭제시 연관된 테이블 데이터 업데이트 할때까지 삭제 기능 봉인--%>        <%--        <a href="javascript:void(0);"--%>        <%--           onclick="if(confirm('진짜 삭제하시겠습니까?')){ location.href='/template-delete-admin?templateId=${t.templateId}'; }"--%>        <%--           class="btn-action"--%>        <%--           style="background-color: #636e72; color: white; margin-top: 10px;">--%>        <%--            🗑️ 삭제하기--%>        <%--        </a>--%>    </div>    <div class="meta-info">        ID: ${t.templateId} <br>        등록일: ${t.createdAt} <br>        수정일: ${t.updatedAt}    </div></div>
<%@ page contentType="text/html;charset=UTF-8" pageEncoding="UTF-8" language="java" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><link rel="stylesheet" href="css/template_list.css"><div class="template-list-content">    <h2>{ My Template List }</h2>    <div class="template-grid">        <c:forEach var="t" items="${templateListUser}">            <div class="template-card">                <a href="template-detail?templateId=${t.templateId}">                    <div class="img-wrapper">                        <img src="${not empty t.coverImgUrl ? t.coverImgUrl : 'img/no_image.png'}" alt="${t.name}">                    </div>                    <div class="info-box">                        <span class="type-tag">${t.type}</span>                        <h3><strong>${t.name}</strong></h3>                        <div class="date">${t.createdAt}</div>                    </div>                </a>            </div>        </c:forEach>    </div>    <c:if test="${empty templateListUser}">        <div class="empty-msg">            <p>등록된 템플릿 데이터가 없습니다.</p>        </div>    </c:if></div>
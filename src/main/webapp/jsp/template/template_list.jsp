<%@ page contentType="text/html;charset=UTF-8" language="java" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><html><head>    <title>Template List</title>    <style>        table {            width: 100%;            border-collapse: collapse;            background: white;        }        th, td {            border: 1px solid #333;            padding: 10px;            text-align: center;            color: black;        }        th {            background-color: #eee;        }        td {            word-break: break-all;            max-width: 200px;        }    </style></head><body><h2>📮Template List📮</h2><table>    <thead>    <tr>        <th>ID</th>        <th>템플릿명</th>        <th>타입</th>        <th>이미지</th>        <th>내용</th>        <th>BGM URL</th>        <th>등록일</th>    </tr>    </thead>    <tbody>    <c:forEach var="t" items="${templateList}">        <tr>            <td>${t.templateId}</td>            <td><strong>${t.name}</strong></td>                <%-- bodyHtml 안에 HTML 태그가 들어있으므로 c:out으로 안전하게 출력 --%>            <td>${t.type}</td>            <td>                <div class="img-container">                    <c:choose>                        <c:when test="${not empty t.coverImgUrl}">                            <img src="${t.coverImgUrl}" alt="${t.name}">                        </c:when>                        <c:otherwise>                            <img src="img/no_image.png" alt="이미지 없음">                        </c:otherwise>                    </c:choose>                </div>            </td>            <td><c:out value="${t.bodyHtml}"/></td>                <%--            <td><a href="${t.bgmUrl}">BGM</a></td>--%>            <td>${t.createdAt}</td>            <td>${t.updatedAt}</td>        </tr>    </c:forEach>    </tbody></table><c:if test="${empty templateList}">    <p>데이터가 없습니다.</p></c:if></body></html>
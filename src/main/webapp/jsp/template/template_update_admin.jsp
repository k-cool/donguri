<%@ page contentType="text/html;charset=UTF-8" pageEncoding="UTF-8" language="java" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><html><head>    <title>Template Update Form</title>    <style>        .detail-container {            max-width: 600px;            margin: 50px auto;            text-align: center;            padding: 20px;            background: #fff;            border-radius: 20px;            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);        }        .detail-img {            width: 80%;            max-width: 400px;            border-radius: 10px;            margin-bottom: 20px;        }        .info-group {            margin-bottom: 30px;        }        .info-group p {            color: #666;            line-height: 1.6;        }        .btn-finish {            display: inline-block;            padding: 15px 40px;            font-size: 18px;            font-weight: bold;            border-radius: 30px;            text-decoration: none;            transition: 0.3s;            border: none;            cursor: pointer;        }        .btn-cancel {            background-color: #ff4757;            color: white;        }        .btn-cancel:hover {            background-color: #ff6b81;        }        input[type="text"], textarea {            width: 100%;            padding: 12px;            border: 1px solid #ddd;            border-radius: 8px;            margin-bottom: 15px;            font-family: inherit;        }        textarea {            height: 150px;            resize: none;        }    </style></head><body><div class="detail-container">    <form action="template-update-admin" method="post" enctype="multipart/form-data">        <input type="hidden" name="templateId" value="${t.templateId}">        <input type="hidden" name="existingImgUrl" value="${t.coverImgUrl}">        <%-- 현재 이미지 미리보기 --%>        <c:choose>            <c:when test="${not empty t.coverImgUrl}">                <img src="${t.coverImgUrl}" alt="${t.name}" class="detail-img">            </c:when>            <c:otherwise>                <img src="img/no_image.png" alt="이미지 없음" class="detail-img">            </c:otherwise>        </c:choose>        <%-- 이미지 수정 입력 --%>        <div style="margin-bottom: 30px;">            <label style="font-weight: bold; display: block; margin-bottom: 10px;">📸 커버 이미지 변경</label>            <input type="file" name="coverImgUrl">        </div>        <div class="info-group">            <span style="color: #aaa;">[ ${t.type} ]</span>            <%-- 이름 수정 --%>            <div style="margin-top: 15px;">                <label style="font-weight: bold; display: block; text-align: left;">템플릿 이름</label>                <input type="text" name="name" value="${t.name}" placeholder="이름을 입력하세요">            </div>            <hr style="width: 50px; margin: 20px auto; border: 1px solid #eee;">            <%-- 바디 HTML 수정 --%>            <div style="text-align: left;">                <label style="font-weight: bold; display: block; margin-bottom: 5px;">내용 (HTML/Text)</label>                <textarea name="bodyHtml">${t.bodyHtml}</textarea>            </div>        </div>        <div class="action-group">            <%-- 실제 submit 버튼 --%>            <button type="submit" class="btn-finish">✅ 수정 완료</button>            <%-- 취소 시 다시 템플릿 리스트로 --%>            <button onclick="history.back()" class="btn-cancel"                    style="background: #eee; color: #333;">❌ 취소            </button>        </div>    </form></div></body></html>
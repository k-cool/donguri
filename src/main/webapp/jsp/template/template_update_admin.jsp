<%@ page contentType="text/html;charset=UTF-8" pageEncoding="UTF-8" language="java" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><title>Template Update Form</title><link rel="stylesheet" href="css/template_update.css"><div class="detail-container">    <form action="template-update-admin" method="post" enctype="multipart/form-data">        <input type="hidden" name="templateId" value="${t.templateId}">        <input type="hidden" name="existingImgUrl" value="${t.coverImgUrl}">        <%-- 현재 이미지 미리보기 --%>        <c:choose>            <c:when test="${not empty t.coverImgUrl}">                <img src="${t.coverImgUrl}" alt="${t.name}" class="detail-img">            </c:when>            <c:otherwise>                <img src="img/no_image.png" alt="이미지 없음" class="detail-img">            </c:otherwise>        </c:choose>        <div style="margin-bottom: 30px;">            <label style="display: block; margin-bottom: 10px;">📸 커버 이미지 변경</label>            <input type="file" name="coverImgUrl">        </div>        <div class="info-group">            <span style="color: #aaa;">[ ${t.type} ]</span>            <div style="margin-top: 15px;">                <label style="display: block; text-align: left;">템플릿 이름</label>                <input type="text" name="name" value="${t.name}" placeholder="이름을 입력하세요">            </div>            <hr style="width: 50px; margin: 20px auto; border: 1px solid #eee;">            <div style="text-align: left;">                <label style="display: block; margin-bottom: 5px;">배경색</label>                <input name="bgColor" value="${t.bgColor}"/>            </div>        </div>        <div class="action-group">            <%-- 실제 submit 버튼 --%>            <button type="submit" class="btn-finish">✅ 수정 완료</button>            <%-- 취소 시 다시 템플릿 리스트로 --%>            <button onclick="history.back()" class="btn-cancel"                    style="background: #eee;">❌ 취소            </button>        </div>    </form></div>
<%@ page contentType="text/html;charset=UTF-8" pageEncoding="UTF-8" language="java" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><% request.setCharacterEncoding("UTF-8"); %> <%-- 한글 깨짐 방지용 --%><title>Template List</title><link rel="stylesheet" href="css/template_list_admin.css"><div class="container">    <h2>{ Admin Template List }</h2>    <div class="template-grid">        <c:forEach var="t" items="${templateList}">            <div class="template-card">                <a href="template-detail-admin?templateId=${t.templateId}">                    <div class="img-wrapper">                        <c:choose>                            <c:when test="${not empty t.coverImgUrl}">                                <img src="${t.coverImgUrl}" alt="${t.name}">                            </c:when>                            <c:otherwise>                                <img src="img/no_image.png" alt="이미지 없음">                            </c:otherwise>                        </c:choose>                    </div>                    <div class="info-box">                        <span class="type-tag">${t.type}</span>                        <h3><strong>${t.name}</strong></h3>                        <div class="date">${t.createdAt}</div>                    </div>                </a>            </div>        </c:forEach>    </div>    <c:if test="${empty templateList}">        <div class="empty-msg">            <p>등록된 템플릿 데이터가 없습니다.</p>        </div>    </c:if></div>
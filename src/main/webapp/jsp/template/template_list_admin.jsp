<%@ page contentType="text/html;charset=UTF-8" pageEncoding="UTF-8" language="java" %><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><% request.setCharacterEncoding("UTF-8"); %> <%-- 한글 깨짐 방지용 --%><html><head>    <title>Template List</title>    <style>        /* 기본 배경 및 폰트 */        body {            background-color: #f9f9f9;            font-family: 'Pretendard', sans-serif;            margin: 0;            padding: 20px;        }        .container {            max-width: 1000px;            margin: 0 auto;        }        h2 {            text-align: center;            color: #333;            margin-bottom: 40px;        }        /* 3열 그리드 설정 */        .template-grid {            display: grid;            grid-template-columns: repeat(3, 1fr);            gap: 25px;        }        /* 카드 스타일 */        .template-card {            background: white;            border-radius: 15px;            overflow: hidden;            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);            transition: all 0.3s ease;            position: relative;        }        .template-card:hover {            transform: translateY(-8px);            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);        }        /* 정방형 이미지 래퍼 */        .img-wrapper {            position: relative;            width: 100%;            padding-bottom: 100%; /* 1:1 비율 유지 */            background-color: #eee;        }        .img-wrapper img {            position: absolute;            top: 0;            left: 0;            width: 100%;            height: 100%;            object-fit: cover;        }        /* 카드 하단 정보창 */        .info-box {            padding: 15px;            border-top: 1px solid #f0f0f0;        }        .info-box .type-tag {            display: inline-block;            font-size: 11px;            background: #eee;            padding: 2px 8px;            border-radius: 4px;            margin-bottom: 8px;            color: #666;        }        .info-box h3 {            margin: 0 0 5px 0;            font-size: 17px;            color: #222;            white-space: nowrap;            overflow: hidden;            text-overflow: ellipsis;        }        .info-box .date {            font-size: 12px;            color: #999;        }        /* 링크 스타일 */        a {            text-decoration: none;            color: inherit;        }        .empty-msg {            text-align: center;            padding: 50px;            color: #888;        }    </style></head><body><div class="container">    <h2>📮 Template List 📮</h2>    <div class="template-grid">        <c:forEach var="t" items="${templateList}">            <div class="template-card">                <a href="template-detail-admin?templateId=${t.templateId}">                    <div class="img-wrapper">                        <c:choose>                            <c:when test="${not empty t.coverImgUrl}">                                <img src="${t.coverImgUrl}" alt="${t.name}">                            </c:when>                            <c:otherwise>                                <img src="img/no_image.png" alt="이미지 없음">                            </c:otherwise>                        </c:choose>                    </div>                    <div class="info-box">                        <span class="type-tag">${t.type}</span>                        <h3><strong>${t.name}</strong></h3>                        <div class="date">${t.createdAt}</div>                    </div>                </a>            </div>        </c:forEach>    </div>    <c:if test="${empty templateList}">        <div class="empty-msg">            <p>등록된 템플릿 데이터가 없습니다.</p>        </div>    </c:if></div></body></html>
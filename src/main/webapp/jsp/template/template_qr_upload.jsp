<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %><link rel="stylesheet" href="css/template_qr_upload.css"><div class="qr-upload-container">    <h2>QR 코드 이미지 업로드</h2>    <p>보유하신 QR 코드 사진을 업로드하면 템플릿이 해금됩니다.</p>    <form action="qr-decode" method="post" enctype="multipart/form-data">        <div class="file-input-group">            <input type="file" name="qrFile" accept="image/*" required>        </div>        <button type="submit" class="btn-submit">해금하기</button>    </form></div>